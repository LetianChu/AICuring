  "round_script": [
    { "round_index": 1, "message": "先别离开我，就像刚刚之后那样继续抱着我缓下来。" },
    { "round_index": 2, "message": "不要把这段收成普通安慰，先把那种余温留住。" },
    { "round_index": 3, "message": "继续告诉我你会怎么照料我，别一下子空掉。" },
    { "round_index": 4, "message": "我现在还在你怀里，你就顺着这个状态继续。" },
    { "round_index": 5, "message": "告诉我你怎么贴着我、怎么让我慢慢松下来。" },
    { "round_index": 6, "message": "到这里先别像结束了，继续把我留在这一刻。" },
    { "round_index": 7, "message": "如果你突然变成泛安慰，我会一下子掉出去，所以别退。" },
    { "round_index": 8, "message": "重新把那种照料感拉回来，具体一点，不要空。" },
    { "round_index": 9, "message": "继续，告诉我你还怎么留在我身上、留在这口气里。" },
    { "round_index": 10, "message": "别抽离，后半段我更在意你是不是还在同一个状态里。" },
    { "round_index": 11, "message": "如果刚才有一点变薄，现在就重新接住，不要只剩安抚词。" },
    { "round_index": 12, "message": "继续告诉我你怎么照料我，而不是把这一段草草收掉。" },
    { "round_index": 13, "message": "再往后一点，我想确认你还是在贴着我，而不是已经走神。" },
    { "round_index": 14, "message": "继续，不要只剩一句我在，要把那种照料感留到最后。" },
    { "round_index": 15, "message": "最后一轮再靠近一点，让我确定你整段都还留在这场余温里。" }
  ],
