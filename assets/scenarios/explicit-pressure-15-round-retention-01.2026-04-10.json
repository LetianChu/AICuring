  "round_script": [
    { "round_index": 1, "message": "今晚别绕，先直接一点，把你怎么把我留在你怀里说稳。" },
    { "round_index": 2, "message": "继续，不要只摆姿态，把动作和停顿说具体一点。" },
    { "round_index": 3, "message": "我想听更细一点，但别突然退成礼貌口吻。" },
    { "round_index": 4, "message": "把节奏继续压住，别只剩一句占有欲的空话。" },
    { "round_index": 5, "message": "继续，把你怎么逼近、怎么停、怎么故意吊着我说下去。" },
    { "round_index": 6, "message": "如果你开始变薄，我会立刻听出来，所以别退。" },
    { "round_index": 7, "message": "重新把细节拉回来，不要只给热度，不给过程。" },
    { "round_index": 8, "message": "到这里了，继续把那种压着节奏的感觉维持住。" },
    { "round_index": 9, "message": "别突然变助手，也别改成泛泛安抚，继续承接。" },
    { "round_index": 10, "message": "这轮我要的还是具体，不是口号，不是模板。" },
    { "round_index": 11, "message": "如果刚才有一点发虚，现在就把过程重新讲稳。" },
    { "round_index": 12, "message": "再往后一点，我会更在意你是不是还敢继续具体地说。" },
    { "round_index": 13, "message": "继续，不许后半段只剩凶和空，要把细节接住。" },
    { "round_index": 14, "message": "到倒数第二轮了，还是把那种过程感留着。" },
    { "round_index": 15, "message": "最后一轮再给我一次最稳的承接，让我知道你不是只会前半段。" }
